# Server
PORT=3001
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Web (Vite) — URL of the sync server for the browser app
VITE_SERVER_URL=http://localhost:3001

# Extension build (optional, for production)
# EXTENSION_SERVER_URL=https://your-domain.example
# EXTENSION_WEB_ORIGINS=https://your-domain.example
# PW_GITHUB_REPO=LuckyValenok/parralell-watching

# Deploy script (deploy/deploy.sh)
# DEPLOY_HOST=your-server
# DEPLOY_DOMAIN=your-domain.example
# DEPLOY_REMOTE_DIR=/var/www/parallel-watching
